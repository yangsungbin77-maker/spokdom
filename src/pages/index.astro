---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import heroBg from '../assets/pool/hero-spokdom.png';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts[0];
const rest = posts.slice(1, 7);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-bg" aria-hidden="true">
					<Image src={heroBg} width={1600} height={914} alt="" loading="eager" />
				</div>
				<div class="hero-copy">
					<span class="eyebrow">Independent · Hands-on · No sponsored rankings</span>
					<h1 class="hero-title">
						Real reviews of AI tools,<br /><span class="neon">scored</span> without the spin.
					</h1>
					<p class="lead">{SITE_DESCRIPTION}</p>
					<div class="hero-actions">
						<a href="/blog" class="btn">Browse reviews</a>
						<a href="/about" class="btn-ghost btn">How we test</a>
					</div>
					<ul class="trust" aria-label="How we review">
						<li>Hands-on testing</li>
						<li>No pay-to-rank</li>
						<li>Updated monthly</li>
					</ul>
				</div>
			</section>

			{
				featured && (
					<a href={`/${featured.id}/`} class="featured">
						{featured.data.heroImage && (
							<div class="featured-image">
								<Image src={featured.data.heroImage} width={1200} height={600} alt={featured.data.title} />
							</div>
						)}
						<div class="featured-body">
							<span class="tag">Latest</span>
							<h2>{featured.data.title}</h2>
							<p>{featured.data.description}</p>
							<span class="meta">
								<FormattedDate date={featured.data.pubDate} /> · Read more →
							</span>
						</div>
					</a>
				)
			}

			{
				rest.length > 0 && (
					<>
						<div class="section-head">
							<h2>More reviews</h2>
							<a href="/blog" class="more">View all →</a>
						</div>
						<ul class="grid">
							{rest.map((post) => (
								<li>
									<a href={`/${post.id}/`} class="card">
										{post.data.heroImage && (
											<div class="card-image">
												<Image src={post.data.heroImage} width={600} height={300} alt={post.data.title} />
											</div>
										)}
										<div class="card-body">
											<h3>{post.data.title}</h3>
											<p>{post.data.description}</p>
											<span class="meta">
												<FormattedDate date={post.data.pubDate} />
											</span>
										</div>
									</a>
								</li>
							))}
						</ul>
					</>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	/* L5: full-bleed custom hero art (Higgsfield Recraft 4.1, 2k) as the
	   background; text sits in the dark left negative space the prompt reserved. */
	.hero {
		position: relative;
		min-height: clamp(420px, 56vh, 560px);
		display: flex;
		align-items: center;
		padding: 3rem 0 3.5rem;
		margin-bottom: 2.5rem;
		border-bottom: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		isolation: isolate;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: -2;
	}
	.hero-bg img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 70% center;
		border-radius: 0;
	}
	/* scrim: keep the left side readable, let the glowing card breathe on the right */
	.hero::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -1;
		background: linear-gradient(
			90deg,
			var(--bg) 0%,
			rgba(11, 14, 20, 0.82) 32%,
			rgba(11, 14, 20, 0.35) 58%,
			transparent 80%
		);
	}
	.hero-copy {
		position: relative;
		max-width: 33rem;
		padding-left: clamp(1rem, 3vw, 2.2rem);
	}

	.eyebrow {
		display: inline-block;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.72rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent);
		opacity: 0.9;
		margin-bottom: 1.1rem;
	}
	.hero-title {
		font-family: 'Space Grotesk', var(--font-heading);
		font-weight: 600;
		font-size: clamp(2.3rem, 5.2vw, 3.7rem);
		line-height: 1.04;
		letter-spacing: -0.02em;
		margin: 0 0 1rem;
	}
	.neon {
		color: var(--accent);
		text-shadow: 0 0 28px var(--accent-glow);
	}
	.lead {
		color: var(--text-muted);
		font-size: 1.12rem;
		max-width: 42ch;
		margin-bottom: 1.6rem;
	}
	.hero-actions {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}
	.trust {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem 1.4rem;
		list-style: none;
		padding: 0;
		margin: 1.7rem 0 0;
		font-family: 'Space Mono', ui-monospace, monospace;
		font-size: 0.78rem;
		color: var(--text-dim);
	}
	.trust li {
		position: relative;
		padding-left: 0.95rem;
	}
	.trust li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.42em;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 8px var(--accent-glow);
	}

	/* page-load stagger */
	.eyebrow,
	.hero-title,
	.lead,
	.hero-actions,
	.trust {
		animation: rise 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
	}
	.hero-title { animation-delay: 0.06s; }
	.lead { animation-delay: 0.12s; }
	.hero-actions { animation-delay: 0.18s; }
	.trust { animation-delay: 0.24s; }

	@keyframes rise {
		from { opacity: 0; transform: translateY(14px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (max-width: 760px) {
		.hero {
			min-height: 0;
			padding: 2.5rem 0 2.8rem;
		}
		/* push the artwork's glowing card to the top, text reads over a stronger scrim */
		.hero-bg img { object-position: 78% 18%; }
		.hero::before {
			background: linear-gradient(
				180deg,
				rgba(11, 14, 20, 0.35) 0%,
				rgba(11, 14, 20, 0.78) 45%,
				var(--bg) 100%
			);
		}
		.hero-copy { padding-left: 0; }
	}
	@media (prefers-reduced-motion: reduce) {
		.eyebrow,
		.hero-title,
		.lead,
		.hero-actions,
		.trust { animation: none; }
	}

	.featured {
		display: block;
		background:
			linear-gradient(180deg, rgba(62, 245, 139, 0.08), transparent 40%),
			var(--bg-elev);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		margin-bottom: 3rem;
		transition: border-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
	}
	.featured:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		box-shadow:
			0 14px 40px rgba(0, 0, 0, 0.4),
			0 0 40px rgba(62, 245, 139, 0.1);
	}
	.featured-image {
		overflow: hidden;
		border-bottom: 1px solid var(--border);
	}
	.featured-image img {
		display: block;
		width: 100%;
		aspect-ratio: 2 / 1;
		object-fit: cover;
		transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.featured:hover .featured-image img { transform: scale(1.04); }
	.featured-body { padding: 2rem; }
	.featured h2 {
		margin: 0.8rem 0 0.5rem;
		font-size: clamp(1.6rem, 3.5vw, 2.3rem);
	}
	.featured p {
		color: var(--text-muted);
		margin-bottom: 1rem;
	}

	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 1.4rem;
	}
	.section-head h2 { margin: 0; }
	.more { font-weight: 600; font-size: 0.95rem; }

	.grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.2rem;
	}
	.card {
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--bg-elev);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		transition: border-color 0.2s ease, transform 0.15s ease, background 0.2s ease,
			box-shadow 0.2s ease;
	}
	/* thin accent line that lights up on hover — encodes "selected pick" */
	.card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: linear-gradient(90deg, var(--accent), transparent 70%);
		opacity: 0;
		transition: opacity 0.2s ease;
		z-index: 2;
	}
	.card:hover {
		border-color: var(--accent);
		transform: translateY(-3px);
		background: var(--bg-elev-2);
		box-shadow: 0 16px 38px rgba(0, 0, 0, 0.42);
	}
	.card:hover::before { opacity: 1; }
	.card-image {
		overflow: hidden;
		border-bottom: 1px solid var(--border);
	}
	.card-image img {
		display: block;
		width: 100%;
		aspect-ratio: 2 / 1;
		object-fit: cover;
		transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.card:hover .card-image img { transform: scale(1.05); }
	.card-body {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: 1.5rem;
	}
	.card h3 {
		margin: 0 0 0.5rem;
		font-size: 1.25rem;
	}
	.card p {
		color: var(--text-muted);
		font-size: 0.95rem;
		margin-bottom: 1rem;
		flex: 1;
	}
	.meta {
		color: var(--text-dim);
		font-size: 0.85rem;
		font-weight: 600;
	}
</style>
